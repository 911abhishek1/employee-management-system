PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/employee_management
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Email (optional) — required only for the "Email Payslip" button.
# Example values below work with Gmail if you generate an "App Password";
# any standard SMTP provider (SendGrid, Mailgun, SES, etc.) also works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
